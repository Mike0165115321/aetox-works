# Aetox Works — Environment (ตัวอย่าง)
# Copy ไฟล์นี้ไปเป็น .env แล้วใส่ค่าจริง

# DeepSeek API (required)
DEEPSEEK_API_KEY=sk-your-key-here
MODEL_NAME=deepseek-v4-flash
BASE_URL=https://api.deepseek.com/v1

# API Server Auth (optional — ถ้าไม่ตั้ง = dev mode ไม่ต้อง auth)
# AETOX_API_KEY=your-secret-api-key-here

# API Server Config
# AETOX_HOST=127.0.0.1
# AETOX_PORT=8000

# External Search APIs (optional)
# FIRECRAWL_API_KEY=fc-your-key
# EXA_API_KEY=your-exa-key
